```bash
#!/bin/bash
# Description: Launch a Next.js development server with robust security and operational checks.
#   - Explicit dependency validation, port management, secure logging, and health checks.
#   - Terminates old node processes that might interfere.
#
# Usage:
#   ./launch_dev.sh

# Configuration
TARGET_DIR="workspace/default"
TARGET_PORT=3001
LOG_FILE="dev_server_3001.log"
PID_FILE=".server_3001.pid"

# --- 1. Context & Dependency Validation ---
# Abort if node_modules is missing, it's a hard requirement. Force explicit management.
if [ ! -d "$TARGET_DIR/node_modules" ]; then
    echo "[ATLAS] FATAL: node_modules missing. Run npm install or npm ci first, then execute this script." >&2
    exit 1
fi

# --- 2. Secure Logging ---
# Ensure the log file exists and has proper permissions.
touch "$LOG_FILE" && chmod 600 "$LOG_FILE"

# --- 3. Port Management (Graceful Termination) ---
# Check if the target port is occupied (lsof -i or ss -lptn are preferred)
# If occupied, check if the process is from this project (node/npm), then kill
# Otherwise, abort if another process.
EXISTING_PID=$(lsof -t -i:"$TARGET_PORT" 2>/dev/null) # POSIX compatible for portability
if [ -n "$EXISTING_PID" ]; then
    PROC_NAME=$(ps -p $EXISTING_PID -o comm=)
    if [[ "$PROC_NAME" == *"node"* ]] || [[ "$PROC_NAME" == *"npm"* ]]; then
        echo "[ATLAS] Terminating existing Node process ($EXISTING_PID) on port $TARGET_PORT..."
        kill -15 $EXISTING_PID # Use SIGTERM for graceful shutdown
        sleep 2              # Give it a moment to shut down
    else
        echo "[ATLAS] FATAL: Port $TARGET_PORT occupied by non-Node process ($PROC_NAME). Aborting." >&2
        exit 1 # Abort if another process is on the port, avoid interfering.
    fi




