```python
import time
import threading
import logging
from concurrent.futures import ThreadPoolExecutor
from atlas_core import AtlasSwarm

logging.basicConfig(level=logging.INFO)
logger = logging.getLogger("AtlasSwarmWrapper")

class AtlasSwarmWrapper:
    def __init__(self, api_key, max_threads=2):
        self.api_key = api_key
        self.max_threads = max_threads
        self.mas = None
        self.executor = ThreadPoolExecutor(max_workers=max_threads, thread_name_prefix="AtlasWorker")
        self._initialize_with_backoff()

    def _initialize_with_backoff(self, retries=5):
        delay = 1
        for i in range(retries):
            try:
                self.mas = AtlasSwarm(self.api_key)
                logger.info("AtlasSwarm initialized successfully.")
                return
            except Exception as e:
                logger.warning(f"AtlasSwarm init failed (attempt {i+1}/{retries}): {e}")
                if i == retries - 1: 
                    logger.error("Max retries reached. Initialization failed.")
                    raise e
                time.sleep(delay)
                delay *= 2

    def execute_task(self, func, *args):
        try:
            self.executor.submit(func, *args)
            return True
        except Exception as e:
            logger.error(f"Task submission failed: {e}")
            return False
            
    def shutdown(self, wait=True):
        logger.info("Shutting down AtlasSwarmWrapper executor...")
