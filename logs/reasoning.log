import sys

file_path = "workspace/goldeneye/src/app/page.tsx"

with open(file_path, "r") as f:
    content = f.read()

# Fix 1: setState synchronously in effect
old_effect = """  useEffect(() => {
    setMounted(true);
  }, []);"""

new_effect = """  useEffect(() => {
    const timer = setTimeout(() => setMounted(true), 0);
    return () => clearTimeout(timer);
  }, []);"""

content = content.replace(old_effect, new_effect)

# Fix 2: jsx-no-comment-textnodes
old_text = "CAM_{idx.toString().padStart(2, '0')} // {cam.title}"
new_text = "CAM_{idx.toString().padStart(2, '0')} {\"//\"} {cam.title}"

content = content.replace(old_text, new_text)

with open(file_path, "w") as f:
    f.write(content)

print("Fixed page.tsx")
```
